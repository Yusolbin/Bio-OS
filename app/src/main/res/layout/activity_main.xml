<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101816"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BIO-OS Plant Pixel View"
            android:textColor="#D8FFE2"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Procedural Pixel Art Visualization"
            android:textColor="#9FD8B1"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <com.cookandroid.bioosapp.PlantPixelView
            android:id="@+id/plantPixelView"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/plantStateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="State: Stable"
            android:textColor="#D8FFE2"
            android:textSize="15sp"
            android:background="#1B2A25"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnStable"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stable" />

            <Button
                android:id="@+id/btnDrought"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Drought" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnHeat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Heat" />

            <Button
                android:id="@+id/btnPruning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pruning" />
        </LinearLayout>

        <Button
            android:id="@+id/btnRecovery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recovery" />

    </LinearLayout>

</ScrollView>